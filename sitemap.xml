<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <!-- ============================================================
         网站地图
         ============================================================
         
         什么是 sitemap？
         网站地图，告诉搜索引擎网站上有哪些页面可以抓取。
         搜索引擎会根据 sitemap 来了解网站结构，加快收录。
         
         ⚠️ 上线前必改：
           把所有 <loc> 标签里的 https://hot.cc/ 替换成你的实际域名
         
         注意：
         - changefreq: 页面更新频率（always/hourly/daily/weekly/monthly/yearly）
         - priority: 页面优先级（0.0-1.0），首页设为 1.0 最高
         - lastmod: 最后修改时间（格式：YYYY-MM-DD）
         
         ============================================================ -->
    
    <!-- 首页 -->
    <url>
        <loc>https://hot.cc/</loc>
        <lastmod>2026-01-01</lastmod>
        <changefreq>hourly</changefreq>
        <priority>1.0</priority>
    </url>
    
    <!-- API 测试页 -->
    <url>
        <loc>https://hot.cc/home/test.html</loc>
        <lastmod>2026-01-01</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.3</priority>
    </url>
    
</urlset>
