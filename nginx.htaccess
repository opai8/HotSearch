# Nginx 伪静态配置参考
# phpStudy 使用 Nginx 时，把以下内容复制到：
# 网站 → 伪静态 → 粘贴保存

location /api/ {
    # 真实文件/目录直接通过
    if (-f $request_filename) {
        break;
    }
    # /api/baidu?limit=10 → /api/index.php/baidu?limit=10
    rewrite ^/api/([a-z0-9]+)$ /api/index.php/$1 last;
}

# 禁止访问 cache 目录
location /cache/ {
    deny all;
    return 404;
}

# 禁止访问隐藏文件
location ~ /\. {
    deny all;
}